-- =============================================
-- MOVEMENT
-- =============================================
local function moveToFast(x, y, z)
    if not player.Character or not player.Character:FindFirstChild("Humanoid") then return false end
    local humanoid = player.Character.Humanoid
    local target = Vector3.new(x, y, z)
    humanoid.WalkSpeed = EXIT_SPEED
    humanoid:MoveTo(target)
    local startTime = tick()
    while tick() - startTime < 6 do
        task.wait(0.1)
        if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
            humanoid.WalkSpeed = 16
            return false
        end
        if (player.Character.HumanoidRootPart.Position - target).Magnitude < 4 then
            humanoid.WalkSpeed = 16
            return true
        end
    end
    humanoid.WalkSpeed = 16
    return false
end

-- =============================================
-- EXIT STATION
-- =============================================
local function exitStation()
    task.wait(3)
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return end
    local pos = player.Character.HumanoidRootPart.Position
    local threshold = 8

    if (pos - Vector3.new(-1176.97668, 15.6500063, -1580.52368)).Magnitude < threshold or
       (pos - Vector3.new(-1188.92676, 15.6500063, -1580.92371)).Magnitude < threshold or
       (pos - Vector3.new(-1164.22668, 15.6500063, -1580.52368)).Magnitude < threshold then
        moveToFast(-1172.60, 18.85, -1592.21) task.wait(0.2)
        moveToFast(-1172.08, 18.70, -1616.77) return
    end

    if (pos - Vector3.new(-1263.19031, 15.3000565, -1547.64966)).Magnitude < threshold then
        moveToFast(-1263.16, 18.70, -1545.10) return
    end

    if (pos - Vector3.new(-1172.82678, 36.0500031, -1582.12366)).Magnitude < threshold then
        moveToFast(-1158.93, 39.10, -1578.16) task.wait(0.2)
        moveToFast(-1157.69, 39.10, -1565.66) task.wait(0.2)
        moveToFast(-1126.55, 39.15, -1566.25) return
    end

    if (pos - Vector3.new(-1145.22668, 15.6500072, -1571.82361)).Magnitude < threshold or
       (pos - Vector3.new(-1120.32666, 15.6500063, -1585.22363)).Magnitude < threshold then
        moveToFast(-1172.99, 18.85, -1584.14) task.wait(0.2)
        moveToFast(-1172.60, 18.85, -1592.21) task.wait(0.2)
        moveToFast(-1172.08, 18.70, -1616.77) return
    end

    if (pos - Vector3.new(741.764648, 35.3023949, 1132.69543)).Magnitude < threshold then
        moveToFast(737.44, 38.79, 1129.58) task.wait(0.2)
        moveToFast(726.17, 38.70, 1084.20) return
    end

    if (pos - Vector3.new(1896.12378, 23.0382195, -841.442078)).Magnitude < threshold or
       (pos - Vector3.new(1801.46631, 23.0382195, -942.035217)).Magnitude < threshold then
        return
    end

    if (pos - Vector3.new(765.782471, 17.1667881, -3345.54126)).Magnitude < threshold then
        moveToFast(764.86, 19.86, -3342.63) task.wait(0.2)
        moveToFast(776.93, 19.88, -3338.16) task.wait(0.2)
        moveToFast(780.80, 19.88, -3348.12) task.wait(0.2)
        moveToFast(803.86, 19.70, -3338.15) return
    end
end

-- =============================================
-- FLY TO AIRDROP
-- =============================================
local function flyToAirdrop(airdrop, session)
    if not airdrop then return false end
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return false end

    currentAirdrop = airdrop
    local targetPart = nil
    for _, child in ipairs(airdrop:GetChildren()) do
        if child:IsA("Part") then targetPart = child break end
    end
    if not targetPart then return false end

    local hrp = player.Character.HumanoidRootPart
    local myPos = hrp.Position
    local targetPos = targetPart.Position

    enableFlight()
    killNPCsInDrop(airdrop)

    -- STEP 1: Gain altitude
    local startTime = tick()
    while hrp.Position.Y < myPos.Y + 380 and tick() - startTime < 20 do
        if farmSession ~= session then disableFlight() return false end
        if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then disableFlight() return false end
        linearVelocity.VectorVelocity = Vector3.new(0, flightSpeed * 0.8, 0)
        alignOrientation.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + Vector3.new(0, 1, 0))
        task.wait(0.1)
        killNPCsInDrop(airdrop)
    end

    -- STEP 2: Fly horizontally
    startTime = tick()
    local arrived = false
    while tick() - startTime < 60 do
        if farmSession ~= session then disableFlight() return false end
        if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then disableFlight() return false end
        if targetPart and targetPart.Parent then targetPos = targetPart.Position end
        local hDist = (Vector3.new(hrp.Position.X, 0, hrp.Position.Z) - Vector3.new(targetPos.X, 0, targetPos.Z)).Magnitude
        if hDist <= 20 then arrived = true break end
        local dir = (Vector3.new(targetPos.X, 0, targetPos.Z) - Vector3.new(hrp.Position.X, 0, hrp.Position.Z)).Unit
        linearVelocity.VectorVelocity = dir * flightSpeed
        alignOrientation.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + dir)
        task.wait(0.1)
        killNPCsInDrop(airdrop)
    end

    if not arrived then disableFlight() return false end

    -- STEP 3: Descend
    local landPos = targetPos + Vector3.new(0, 3, 0)
    startTime = tick()
    while (hrp.Position - landPos).Magnitude > 3 and tick() - startTime < 10 do
        if farmSession ~= session then disableFlight() return false end
        if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then disableFlight() return false end
        local dir = (landPos - hrp.Position).Unit
        linearVelocity.VectorVelocity = dir * (flightSpeed * 0.4)
        alignOrientation.CFrame = CFrame.lookAt(hrp.Position, hrp.Position + dir)
        task.wait(0.1)
        killNPCsInDrop(airdrop)
    end

    if farmSession ~= session then disableFlight() return false end

    linearVelocity.VectorVelocity = Vector3.new(0, 0, 0)
    task.wait(0.1)

    if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
        player.Character.HumanoidRootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        player.Character.HumanoidRootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
    end

    if player.Character and player.Character:FindFirstChild("Humanoid") then
        player.Character.Humanoid.Health = player.Character.Humanoid.MaxHealth
    end

    disableFlight()
    print("✅ Landed on airdrop!")
    return true
end

-- =============================================
-- COLLECT AIRDROP
-- =============================================
local function collectAirdrop(airdrop, session)
    if collecting then return false end
    collecting = true

    local targetPart = nil
    for _, child in ipairs(airdrop:GetChildren()) do
        if child:IsA("Part") then targetPart = child break end
    end
    if not targetPart then collecting = false return false end

    vim:SendKeyEvent(true, Enum.KeyCode.E, false, nil)

    local maxWait = 60
    local elapsed = 0
    while elapsed < maxWait do
        task.wait(0.5)
        elapsed = elapsed + 0.5

        if farmSession ~= session then
            vim:SendKeyEvent(false, Enum.KeyCode.E, false, nil)
            collecting = false
            return false
        end

        airdropStatus.Text = "🪂 Collecting... " .. math.floor(elapsed) .. "/" .. maxWait

        local killed = killNPCsInDrop(airdrop)
        if killed > 0 then npcStatus.Text = "🔫 NPC Killer: Killed " .. killed end

        if not airdrop or not airdrop.Parent then
            vim:SendKeyEvent(false, Enum.KeyCode.E, false, nil)
            collecting = false
            currentAirdrop = nil
            return true
        end

        if player.Character and player.Character:FindFirstChild("Humanoid") and targetPart and targetPart.Parent then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            if hrp and (hrp.Position - targetPart.Position).Magnitude > 6 then
                player.Character.Humanoid:MoveTo(targetPart.Position)
            end
        end
    end

    vim:SendKeyEvent(false, Enum.KeyCode.E, false, nil)

    if not airdrop or not airdrop.Parent then
        collecting = false
        currentAirdrop = nil
        return true
    end

    collecting = false
    return false
end

