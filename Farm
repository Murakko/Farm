-- =============================================
-- FLIGHT
-- =============================================
local function enableFlight()
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then return false end
    local hrp = player.Character.HumanoidRootPart
    local humanoid = player.Character:FindFirstChild("Humanoid")
    if humanoid then
        humanoid.PlatformStand = true
        humanoid.WalkSpeed = 0
        humanoid.JumpPower = 0
        humanoid.AutoRotate = false
    end
    if linearVelocity then pcall(function() linearVelocity:Destroy() end) linearVelocity = nil end
    if alignOrientation then pcall(function() alignOrientation:Destroy() end) alignOrientation = nil end
    if attachment then pcall(function() attachment:Destroy() end) attachment = nil end
    attachment = Instance.new("Attachment")
    attachment.Parent = hrp
    linearVelocity = Instance.new("LinearVelocity")
    linearVelocity.Attachment0 = attachment
    linearVelocity.MaxForce = 4000
    linearVelocity.VelocityConstraintMode = Enum.VelocityConstraintMode.Vector
    linearVelocity.VectorVelocity = Vector3.new(0, 0, 0)
    linearVelocity.Parent = hrp
    alignOrientation = Instance.new("AlignOrientation")
    alignOrientation.Attachment0 = attachment
    alignOrientation.MaxTorque = 4000
    alignOrientation.MaxAngularVelocity = 100
    alignOrientation.Responsiveness = 50
    alignOrientation.CFrame = hrp.CFrame
    alignOrientation.Parent = hrp
    return true
end

local function disableFlight()
    if linearVelocity then pcall(function() linearVelocity:Destroy() end) linearVelocity = nil end
    if alignOrientation then pcall(function() alignOrientation:Destroy() end) alignOrientation = nil end
    if attachment then pcall(function() attachment:Destroy() end) attachment = nil end
    if player.Character and player.Character:FindFirstChild("Humanoid") then
        local humanoid = player.Character.Humanoid
        humanoid.PlatformStand = false
        humanoid.WalkSpeed = 16
        humanoid.JumpPower = 50
        humanoid.AutoRotate = true
    end
end

-- =============================================
-- NPC KILLER
-- =============================================
local function killNPCsInDrop(airdrop)
    if not airdrop then return 0 end
    local killedCount = 0
    local npcFolder = airdrop:FindFirstChild("NPCs")
    if npcFolder then
        for _, npc in ipairs(npcFolder:GetChildren()) do
            if npc:IsA("Model") then
                pcall(function() npc:Destroy() killedCount = killedCount + 1 end)
            end
        end
    end
    for _, child in ipairs(airdrop:GetChildren()) do
        if child:IsA("Model") and (
            child.Name:find("Bodyguard") or child.Name:find("Chaser") or
            child.Name:find("Enforcer") or child.Name:find("Sniper") or
            child.Name:find("Guard")
        ) then
            pcall(function() child:Destroy() killedCount = killedCount + 1 end)
        end
    end
    return killedCount
end

local function startNPCKiller()
    task.spawn(function()
        while true do
            if currentAirdrop and currentAirdrop.Parent then
                local killed = killNPCsInDrop(currentAirdrop)
                if killed > 0 then npcStatus.Text = "🔫 NPC Killer: Killed " .. killed end
            end
            task.wait(0.1)
        end
    end)
end

