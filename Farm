    isHopping = true
    print("🔀 Server hopping...")
    airdropStatus.Text = "🔀 Server hopping..."
    airdropStatus.TextColor3 = Color3.fromRGB(255, 165, 0)

    local success, err = pcall(function()
        teleportService:Teleport(game.PlaceId, player, {autoFarm = true})
    end)

    if not success then
